<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Articles</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUa6mY5Y2v+0k2m4Yd0aVQbX1K4e1Zl6qZ6q3Q9Z6m6Y8h1f4g5r2W9nQ9W2" crossorigin="anonymous">
    <style>
        body { background: #f8f9fa; }
        .article-card { transition: transform .12s ease, box-shadow .12s ease; }
        .article-card:hover { transform: translateY(-6px); box-shadow: 0 8px 24px rgba(0,0,0,.08); }
        .card-text { max-height: 6.5rem; overflow: hidden; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">My Blog</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu" aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/articles">Articles</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container my-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Articles</h1>
            <a href="/articles/new" class="btn btn-success">New Article</a>
        </div>

        <div class="row g-4">
            <% if (articles && articles.length) { %>
                <% articles.forEach(article => { %>
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card h-100 article-card">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title"><%= article.title %></h5>
                                <p class="card-text text-muted mb-3"><%= (article.content && article.content.length > 240) ? article.content.slice(0,240) + '...' : article.content %></p>
                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                    <small class="text-muted">Likes: <span class="badge bg-primary"><%= article.numberoflikes %></span></small>
                                    <div>
                                        <a href="/articles/<%= article.id || article._id %>" class="btn btn-sm btn-outline-primary">View</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12">
                    <div class="alert alert-info">No articles yet. Create the first one!</div>
                </div>
            <% } %>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-ENjdO4Dr2bkBIFxQpeoA6V+8Qbsw3v9p1Zl+3e6q3q9K2m6Y9f1g4h5r2W8nQ9W3" crossorigin="anonymous"></script>
</body>
</html>